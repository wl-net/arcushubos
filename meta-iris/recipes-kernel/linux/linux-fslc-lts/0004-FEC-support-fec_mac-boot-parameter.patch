+/* Support fec_mac=AA:BB:CC:DD:EE:FF boot parameter (NXP 3.0.35 compat) */
+static unsigned char fec_mac[ETH_ALEN];
+static int __init parse_fec_mac(char *options)
+{
+	char *tmp, *end;
+	int j;
+
+	if (options == NULL)
+		return 1;
+
+	tmp = options;
+	for (j = 0; j < 6; j++) {
+		fec_mac[j] = tmp ? simple_strtoul(tmp, &end, 16) : 0;
+		if (tmp)
+			tmp = (*end) ? end + 1 : end;
+	}
+	return 1;
+}
+__setup("fec_mac=", parse_fec_mac);
