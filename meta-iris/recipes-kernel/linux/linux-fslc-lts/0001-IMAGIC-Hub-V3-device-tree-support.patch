diff --git a/arch/arm/boot/dts/nxp/imx/imx6q-imagic.dts b/arch/arm/boot/dts/nxp/imx/imx6q-imagic.dts
new file mode 100644
index 000000000..0ee94a0e6
--- /dev/null
+++ b/arch/arm/boot/dts/nxp/imx/imx6q-imagic.dts
@@ -0,0 +1,14 @@
+// SPDX-License-Identifier: GPL-2.0+
+/dts-v1/;
+
+#include "imx6q.dtsi"
+#include "imx6qdl-imagic.dtsi"
+
+/ {
