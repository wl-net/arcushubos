From 8705c0dbc56285788ed03425b3c0c627e06d61dd Mon Sep 17 00:00:00 2001
From: Andrew Sorensen <andrew@andrewsorensen.net>
Date: Thu, 26 Feb 2026 00:48:51 -0800
Subject: [PATCH 2/3] IMAGIC Hub V3 custom driver support

Add four custom misc drivers for Hub V3 hardware:
- buzzer.c: GPIO buzzer with ioctl interface
- mbi6023.c: MBI6023 LED ring controller (39-word bit-banged SPI)
- imagic_watchdog.c: External GPIO watchdog timer
- imagic_imx6_gpio.c: General-purpose GPIO control from userspace

Add NFC (ST 95HF) GPIO ioctls and compatible string to spidev.
Add Kconfig entries and Makefile rules for all four drivers.

diff --git a/drivers/misc/Kconfig b/drivers/misc/Kconfig
index 1d57b933d..1bfa1e6ad 100644
--- a/drivers/misc/Kconfig
+++ b/drivers/misc/Kconfig
@@ -569,6 +569,35 @@ config UBOOT_BOOTCOUNT
 	  The U-Boot Bootcount driver allows to access the
 	  bootcounter through sysFS file.
 
+config IMAGIC_WATCH_DOG
+	tristate "IMAGIC Hub V3 GPIO Watchdog"
+	depends on GPIOLIB && OF
+	help
+	  GPIO-based external watchdog timer for IMAGIC Hub V3.
+	  Provides a miscdevice interface to feed/enable/disable the
+	  external watchdog via GPIO pins.
+
+config MBI6023
+	tristate "IMAGIC Hub V3 MBI6023 LED Ring"
+	depends on GPIOLIB
+	help
+	  Bit-banged SPI driver for MBI6023 LED controller on IMAGIC Hub V3.
+	  Controls 12 RGB LED groups (39 words) via GPIO pins.
+
+config BUZZER
+	tristate "IMAGIC Hub V3 GPIO Buzzer"
+	depends on GPIOLIB && OF
+	help
+	  GPIO buzzer driver for IMAGIC Hub V3.
+
+config IMX6_GPIO_TEST
+	tristate "IMAGIC Hub V3 GPIO Control"
+	depends on GPIOLIB && OF
+	help
+	  GPIO control driver for IMAGIC Hub V3. Provides userspace
+	  ioctl access to GPIOs and configures board-specific GPIOs
+	  from device tree on probe.
+
 source "drivers/misc/c2port/Kconfig"
 source "drivers/misc/eeprom/Kconfig"
 source "drivers/misc/cb710/Kconfig"
