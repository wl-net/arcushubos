From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Date: Wed, 22 Nov 2017 15:45:17 -0500
Subject: [PATCH] Iris dtsi config changes for Hub V2
Upstream-Status: Inappropriate [Iris Hub V2 specific]

Customize am335x BeagleBone Black device tree for Iris Hub V2:
- Rename LEDs to green/yellow/red, disable default triggers, remove led5
- Switch USB0 to host mode
- Add UART1/2/4 pin muxes for radio serial ports
- Add PWM buzzer on ehrpwm2B (P8_13)
- Disable RTC (not present on Hub V2 hardware)
- Add MMC aliases so eMMC = mmcblk0, SD = mmcblk1

---
 arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi      | 25 ++++------
 arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi | 66 +++++++++++++++++++++++++++
 2 files changed, 76 insertions(+), 15 deletions(-)

diff --git a/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi b/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
index 96451c8a815c..7909deab3993 100644
--- a/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
@@ -26,30 +26,23 @@ leds {
 		compatible = "gpio-leds";

 		led2 {
-			label = "beaglebone:green:heartbeat";
+			label = "green";
 			gpios = <&gpio1 21 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "heartbeat";
+			linux,default-trigger = "none";
 			default-state = "off";
 		};

 		led3 {
-			label = "beaglebone:green:mmc0";
+			label = "yellow";
 			gpios = <&gpio1 22 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "mmc0";
+			linux,default-trigger = "none";
 			default-state = "off";
 		};

 		led4 {
-			label = "beaglebone:green:usr2";
+			label = "red";
 			gpios = <&gpio1 23 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "cpu0";
-			default-state = "off";
-		};
-
-		led5 {
-			label = "beaglebone:green:usr3";
-			gpios = <&gpio1 24 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "mmc1";
+			linux,default-trigger = "none";
 			default-state = "off";
 		};
 	};
@@ -196,7 +189,7 @@ &uart0 {
 };

 &usb0 {
-	dr_mode = "peripheral";
+	dr_mode = "host";
 	interrupts-extended = <&intc 18 &tps 0>;
 	interrupt-names = "mc", "vbus";
 };
@@ -408,7 +401,7 @@ &sham {
 &rtc {
 	clocks = <&clk_32768_ck>, <&clk_24mhz_clkctrl AM3_CLK_24MHZ_CLKDIV32K_CLKCTRL 0>;
 	clock-names = "ext-clk", "int-clk";
-	system-power-controller;
+	status = "disabled";
 };

 &pruss_tm {
diff --git a/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi b/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
index a7a8c61ef9b2..6e46e15a28c7 100644
--- a/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
@@ -22,7 +22,73 @@ &mmc2 {
 	non-removable;
 };

+&am33xx_pinmux {
+	uart1_pins: pinmux_uart1_pins {
+		pinctrl-single,pins = <
+			0x180 (PIN_INPUT_PULLUP | MUX_MODE0)	/* uart1_rxd */
+			0x184 (PIN_OUTPUT_PULLDOWN | MUX_MODE0)	/* uart1_txd */
+		>;
+	};
+
+	uart2_pins: pinmux_uart2_pins {
+		pinctrl-single,pins = <
+			0x150 (PIN_INPUT_PULLUP | MUX_MODE1)	/* uart2_rxd */
+			0x154 (PIN_OUTPUT_PULLDOWN | MUX_MODE1)	/* uart2_txd */
+			0x0C0 (PIN_INPUT | MUX_MODE6)		/* UART2_CTSN = lcd_data8, MODE6 */
+			0x0C4 (PIN_OUTPUT | MUX_MODE6)		/* UART2_RTSN = lcd_data9, MODE6 */
+		>;
+	};
+
+	uart4_pins: pinmux_uart4_pins {
+		pinctrl-single,pins = <
+			0x70 (PIN_INPUT_PULLUP | MUX_MODE6)	/* uart4_rxd */
+			0x74 (PIN_OUTPUT_PULLDOWN | MUX_MODE6)	/* uart4_txd */
+			0x0D0 (PIN_INPUT | MUX_MODE6)		/* UART4_CTSN = lcd_data12, MODE6 */
+			0x0D4 (PIN_OUTPUT | MUX_MODE6)		/* UART4_RTSN = lcd_data13, MODE6 */
+		>;
+	};
+
+	pwm_buzzer_ext1_pins: pinmux_pwm_buzzer_ext1_pins {
+		pinctrl-single,pins = <
+			0x024 (PIN_OUTPUT_PULLDOWN | MUX_MODE4)	/* gpmc_ad9 = ehrpwm2B = P8_13 */
+		>;
+	};
+};
+
+&uart1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart1_pins>;
+	status = "okay";
+};
+
+&uart2 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart2_pins>;
+	status = "okay";
+};
+
+&uart4 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart4_pins>;
+	status = "okay";
+};
+
+&epwmss2 {
+	status = "okay";
+};
+
+&ehrpwm2 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&pwm_buzzer_ext1_pins>;
+	status = "okay";
+};
+
 / {
+	aliases {
+		mmc0 = &mmc2;	/* eMMC = mmcblk0 */
+		mmc1 = &mmc1;	/* SD card = mmcblk1 */
+	};
+
 	memory@80000000 {
 		device_type = "memory";
 		reg = <0x80000000 0x20000000>; /* 512 MB */
--
2.17.1
