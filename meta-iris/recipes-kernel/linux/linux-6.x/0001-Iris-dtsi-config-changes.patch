From b56851a659dca2effa9eb11ba80a4722d0f2ab92 Mon Sep 17 00:00:00 2001
From: Andrew Sorensen <andrew@andrewsorensen.net>
Date: Wed, 25 Feb 2026 09:53:23 -0800
Subject: [PATCH 1/2] Iris dtsi config changes for Hub V2
Upstream-Status: Inappropriate [Iris Hub V2 specific]

---
 .../boot/dts/ti/omap/am335x-bone-common.dtsi  | 23 +++---
 .../dts/ti/omap/am335x-boneblack-common.dtsi  | 79 +++++++++++++++++++
 .../dts/ti/omap/am335x-boneblack-hdmi.dtsi    |  5 +-
 arch/arm/boot/dts/ti/omap/am33xx-l4.dtsi      |  1 +
 4 files changed, 91 insertions(+), 17 deletions(-)

diff --git a/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi b/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
index 96451c8a815c..7909deab3993 100644
--- a/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am335x-bone-common.dtsi
@@ -26,30 +26,23 @@ leds {
 		compatible = "gpio-leds";
 
 		led2 {
-			label = "beaglebone:green:heartbeat";
+			label = "green";
 			gpios = <&gpio1 21 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "heartbeat";
+			linux,default-trigger = "heartbeat";
 			default-state = "off";
 		};

 		led3 {
-			label = "beaglebone:green:mmc0";
+			label = "yellow";
 			gpios = <&gpio1 22 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "mmc0";
+			linux,default-trigger = "none";
 			default-state = "off";
 		};
 
 		led4 {
-			label = "beaglebone:green:usr2";
+			label = "red";
 			gpios = <&gpio1 23 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "cpu0";
-			default-state = "off";
-		};
-
-		led5 {
-			label = "beaglebone:green:usr3";
-			gpios = <&gpio1 24 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "mmc1";
+			linux,default-trigger = "none";
 			default-state = "off";
 		};
 	};
@@ -196,7 +189,7 @@ &uart0 {
 };
 
 &usb0 {
-	dr_mode = "peripheral";
+	dr_mode = "host";
 	interrupts-extended = <&intc 18 &tps 0>;
 	interrupt-names = "mc", "vbus";
 };
@@ -408,7 +401,7 @@ &sham {
 &rtc {
 	clocks = <&clk_32768_ck>, <&clk_24mhz_clkctrl AM3_CLK_24MHZ_CLKDIV32K_CLKCTRL 0>;
 	clock-names = "ext-clk", "int-clk";
-	system-power-controller;
+	status = "disabled";
 };
 
 &pruss_tm {
diff --git a/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi b/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
index a7a8c61ef9b2..ba82eb476356 100644
--- a/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am335x-boneblack-common.dtsi
@@ -22,7 +22,88 @@ &mmc2 {
 	non-removable;
 };
 
+&am33xx_pinmux {
+	uart1_pins: pinmux_uart1_pins {
+		pinctrl-single,pins = <
+			AM33XX_PADCONF(AM335X_PIN_UART1_RXD, PIN_INPUT_PULLUP, MUX_MODE0)	/* uart1_rxd */
+			AM33XX_PADCONF(AM335X_PIN_UART1_TXD, PIN_OUTPUT_PULLDOWN, MUX_MODE0)	/* uart1_txd */
+		>;
+	};
+
+	uart2_pins: pinmux_uart2_pins {
+		pinctrl-single,pins = <
+			AM33XX_PADCONF(AM335X_PIN_SPI0_SCLK, PIN_INPUT_PULLUP, MUX_MODE1)	/* uart2_rxd */
+			AM33XX_PADCONF(AM335X_PIN_SPI0_D0, PIN_OUTPUT_PULLDOWN, MUX_MODE1)	/* uart2_txd */
+			AM33XX_PADCONF(AM335X_PIN_LCD_DATA8, PIN_INPUT, MUX_MODE6)		/* uart2_ctsn */
+			AM33XX_PADCONF(AM335X_PIN_LCD_DATA9, PIN_OUTPUT, MUX_MODE6)		/* uart2_rtsn */
+		>;
+	};
+
+	uart4_pins: pinmux_uart4_pins {
+		pinctrl-single,pins = <
+			AM33XX_PADCONF(AM335X_PIN_GPMC_WAIT0, PIN_INPUT_PULLUP, MUX_MODE6)	/* uart4_rxd */
+			AM33XX_PADCONF(AM335X_PIN_GPMC_WPN, PIN_OUTPUT_PULLDOWN, MUX_MODE6)	/* uart4_txd */
+			AM33XX_PADCONF(AM335X_PIN_LCD_DATA12, PIN_INPUT, MUX_MODE6)		/* uart4_ctsn */
+			AM33XX_PADCONF(AM335X_PIN_LCD_DATA13, PIN_OUTPUT, MUX_MODE6)		/* uart4_rtsn */
+		>;
+	};
+
+	pwm_buzzer_ext1_pins: pinmux_pwm_buzzer_ext1_pins {
+		pinctrl-single,pins = <
+			AM33XX_PADCONF(AM335X_PIN_GPMC_AD9, PIN_OUTPUT_PULLDOWN, MUX_MODE4)	/* ehrpwm2B */
+		>;
+	};
+};
+
+&uart1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart1_pins>;
+	/delete-property/ dmas;
+	/delete-property/ dma-names;
+	status = "okay";
+};
+
+&uart2 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart2_pins>;
+	/delete-property/ dmas;
+	/delete-property/ dma-names;
+	uart-has-rtscts;
+	status = "okay";
+};
+
+&uart4 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart4_pins>;
+	uart-has-rtscts;
+	status = "okay";
+};
+
+&epwmss2 {
+	status = "okay";
+};
+
+&ehrpwm2 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&pwm_buzzer_ext1_pins>;
+	status = "okay";
+};
+
+/* Hub V2 has no PRUSS — disable to prevent ti-sysc probe crash */
+&pruss_tm {
+	status = "disabled";
+};
+
 / {
+	aliases {
+		mmc0 = &mmc2;	/* eMMC = mmcblk0 */
+		mmc1 = &mmc1;	/* SD card = mmcblk1 */
+		gpio0 = &gpio0;
+		gpio1 = &gpio1;
+		gpio2 = &gpio2;
+		gpio3 = &gpio3;
+	};
+
 	memory@80000000 {
 		device_type = "memory";
 		reg = <0x80000000 0x20000000>; /* 512 MB */
diff --git a/arch/arm/boot/dts/ti/omap/am335x-boneblack-hdmi.dtsi b/arch/arm/boot/dts/ti/omap/am335x-boneblack-hdmi.dtsi
index 109f08fd174d..e435abc1d95d 100644
--- a/arch/arm/boot/dts/ti/omap/am335x-boneblack-hdmi.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am335x-boneblack-hdmi.dtsi
@@ -51,7 +51,7 @@ AM33XX_PADCONF(AM335X_PIN_GPMC_A11, PIN_OUTPUT_PULLDOWN, MUX_MODE7) /* gpmc_a11.
 };
 
 &lcdc {
-	status = "okay";
+	status = "disabled";
 
 	/* If you want to get 24 bit RGB and 16 BGR mode instead of
 	 * current 16 bit RGB and 24 BGR modes, set the propety
@@ -69,6 +69,7 @@ lcdc_0: endpoint@0 {
 
 &i2c0 {
 	tda19988: tda19988@70 {
+		status = "disabled";
 		compatible = "nxp,tda998x";
 		reg = <0x70>;
 		nxp,calib-gpios = <&gpio1 25 0>;
@@ -103,7 +104,7 @@ &mcasp0	{
 	#sound-dai-cells = <0>;
 	pinctrl-names = "default";
 	pinctrl-0 = <&mcasp0_pins>;
-	status = "okay";
+	status = "disabled";
 	op-mode = <0>;	/* MCASP_IIS_MODE */
 	tdm-slots = <2>;
 	serial-dir = <	/* 0: INACTIVE, 1: TX, 2: RX */
diff --git a/arch/arm/boot/dts/ti/omap/am33xx-l4.dtsi b/arch/arm/boot/dts/ti/omap/am33xx-l4.dtsi
index d6a143abae5f..7df2b7513196 100644
--- a/arch/arm/boot/dts/ti/omap/am33xx-l4.dtsi
+++ b/arch/arm/boot/dts/ti/omap/am33xx-l4.dtsi
@@ -436,6 +436,7 @@ target-module@39000 {			/* 0x44e39000, ap 33 02.0 */
 		};
 
 		target-module@3e000 {			/* 0x44e3e000, ap 35 60.0 */
+			status = "disabled";
 			compatible = "ti,sysc-omap4-simple", "ti,sysc";
 			reg = <0x3e074 0x4>,
 			      <0x3e078 0x4>;
-- 
2.39.5

